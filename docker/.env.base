###
# Runtime settings
###

# Isaac Lab base image used by docker/build.sh.
ISAACLAB_IMAGE=nvcr.io/nvidia/isaac-lab:2.3.1

# Local image produced by docker/build.sh and used by docker/run.sh.
LEGGED_LAB_IMAGE=legged-lab:latest

CONTAINER_NAME=legged-lab

# Path is resolved relative to this docker directory.
RSL_RL_PATH=../../rsl_rl
